# Database Connection (FastAPI asyncpg engine format)
# Local Docker Compose defaults to: postgresql+asyncpg://postgres:postgres@db:5432/docmind
# Local system runs default to: postgresql+asyncpg://postgres:postgres@localhost:5432/docmind
DATABASE_URL=postgresql+asyncpg://neondb_owner:npg_9goyvFrj7IYG@ep-fancy-bird-aul77m6q.c-10.us-east-1.aws.neon.tech/neondb?ssl=require

# JWT Signature Cryptography Secret
# Keep this secure in production. Change it to a random hash
JWT_SECRET_KEY=b5a2345c1104d892ad76cd7fa2c069fda35a22f485d4de95d8889172c08c4170
JWT_ALGORITHM=HS256

# OpenAI API Key Credentials
